#include "cpu.h"
#include <cstdint>
#include <iomanip>
#include <iostream>
#include <stdexcept>

CPU::CPU(Bus& bus) : bus_(bus) {}

void CPU::reset(uint32_t pc) {
    pc_ = pc;
    regs_.fill(0);
}

void CPU::set_trace(bool enabled) {
    trace_ = enabled;
}

void CPU::dump_regs() const {
    std::cout << "\n=== Register Dump ===\n";
    for (int i = 0; i < 32; ++i) {
        std::cout << "x" << std::dec << std::setw(2) << std::setfill(' ') << i
                  << " = 0x" << std::hex << std::setw(8) << std::setfill('0')
                  << (i == 0 ? 0u : regs_[i]);

        if ((i % 4) == 3) {
            std::cout << "\n";
        } else {
            std::cout << "    ";
        }
    }
    std::cout << "pc = 0x" << std::hex << std::setw(8) << std::setfill('0') << pc_ << "\n";
    std::cout << std::dec;
}

int32_t CPU::sign_extend(uint32_t value, int bits) {
    uint32_t mask = 1u << (bits - 1);
    return static_cast<int32_t>((value ^ mask) - mask);
}

uint32_t CPU::load_reg(uint32_t idx) const {
    return idx == 0 ? 0 : regs_[idx];
}

void CPU::store_reg(uint32_t idx, uint32_t value) {
    if (idx != 0) {
        regs_[idx] = value;
        if (trace_) {
            std::cout << "    x" << std::dec << idx
                      << " <= 0x" << std::hex << std::setw(8)
                      << std::setfill('0') << value << std::dec << "\n";
        }
    }
}

uint32_t CPU::fetch32(uint32_t addr) {
    return bus_.load32(addr);
}

void CPU::run(uint64_t max_cycles) {
    uint64_t cycles = 0;
    while (!bus_.halted() && cycles < max_cycles) {
        step();
        cycles++;
    }

    if (cycles >= max_cycles) {
        throw std::runtime_error("Simulation stopped: max cycles reached");
    }
}

void CPU::step() {
    uint32_t inst = fetch32(pc_);
    uint32_t opcode = inst & 0x7f;

    if (trace_) {
        std::cout << "[TRACE] pc=0x"
                  << std::hex << std::setw(8) << std::setfill('0') << pc_
                  << " inst=0x"
                  << std::hex << std::setw(8) << std::setfill('0') << inst
                  << std::dec << "\n";
    }

    switch (opcode) {
        case 0x37: exec_lui(inst); break;
        case 0x17: exec_auipc(inst); break;
        case 0x6f: exec_jal(inst); break;
        case 0x67: exec_jalr(inst); break;
        case 0x63: exec_branch(inst); break;
        case 0x03: exec_load(inst); break;
        case 0x23: exec_store(inst); break;
        case 0x13: exec_op_imm(inst); break;
        case 0x33: exec_op(inst); break;
        case 0x73: exec_system(inst); break;
        default:
            throw std::runtime_error("Unsupported opcode");
    }

    regs_[0] = 0;
}

void CPU::exec_lui(uint32_t inst) {
    uint32_t rd = (inst >> 7) & 0x1f;
    uint32_t imm = inst & 0xfffff000;
    store_reg(rd, imm);
    pc_ += 4;
}

void CPU::exec_auipc(uint32_t inst) {
    uint32_t rd = (inst >> 7) & 0x1f;
    uint32_t imm = inst & 0xfffff000;
    store_reg(rd, pc_ + imm);
    pc_ += 4;
}

void CPU::exec_jal(uint32_t inst) {
    uint32_t rd = (inst >> 7) & 0x1f;

    uint32_t imm20    = ((inst >> 31) & 0x1) << 20;
    uint32_t imm10_1  = ((inst >> 21) & 0x3ff) << 1;
    uint32_t imm11    = ((inst >> 20) & 0x1) << 11;
    uint32_t imm19_12 = ((inst >> 12) & 0xff) << 12;
    int32_t imm = sign_extend(imm20 | imm19_12 | imm11 | imm10_1, 21);

    uint32_t next_pc = pc_ + 4;
    pc_ = pc_ + imm;
    store_reg(rd, next_pc);
}

void CPU::exec_jalr(uint32_t inst) {
    uint32_t rd  = (inst >> 7) & 0x1f;
    uint32_t rs1 = (inst >> 15) & 0x1f;
    int32_t imm  = sign_extend(inst >> 20, 12);

    uint32_t next_pc = pc_ + 4;
    pc_ = (load_reg(rs1) + imm) & ~1u;
    store_reg(rd, next_pc);
}

void CPU::exec_branch(uint32_t inst) {
    uint32_t funct3 = (inst >> 12) & 0x7;
    uint32_t rs1    = (inst >> 15) & 0x1f;
    uint32_t rs2    = (inst >> 20) & 0x1f;

    uint32_t imm12   = ((inst >> 31) & 0x1) << 12;
    uint32_t imm10_5 = ((inst >> 25) & 0x3f) << 5;
    uint32_t imm4_1  = ((inst >> 8) & 0xf) << 1;
    uint32_t imm11   = ((inst >> 7) & 0x1) << 11;
    int32_t imm = sign_extend(imm12 | imm11 | imm10_5 | imm4_1, 13);

    uint32_t a = load_reg(rs1);
    uint32_t b = load_reg(rs2);

    bool taken = false;
    switch (funct3) {
        case 0x0: taken = (a == b); break;
        case 0x1: taken = (a != b); break;
        case 0x4: taken = (static_cast<int32_t>(a) <  static_cast<int32_t>(b)); break;
        case 0x5: taken = (static_cast<int32_t>(a) >= static_cast<int32_t>(b)); break;
        case 0x6: taken = (a < b); break;
        case 0x7: taken = (a >= b); break;
        default: throw std::runtime_error("Unsupported branch funct3");
    }

    pc_ = taken ? (pc_ + imm) : (pc_ + 4);
}

void CPU::exec_load(uint32_t inst) {
    uint32_t rd     = (inst >> 7) & 0x1f;
    uint32_t funct3 = (inst >> 12) & 0x7;
    uint32_t rs1    = (inst >> 15) & 0x1f;
    int32_t imm     = sign_extend(inst >> 20, 12);

    uint32_t addr = load_reg(rs1) + imm;
    uint32_t value = 0;

    switch (funct3) {
        case 0x0: value = static_cast<uint32_t>(sign_extend(bus_.load8(addr), 8)); break;
        case 0x1: value = static_cast<uint32_t>(sign_extend(bus_.load16(addr), 16)); break;
        case 0x2: value = bus_.load32(addr); break;
        case 0x4: value = bus_.load8(addr); break;
        case 0x5: value = bus_.load16(addr); break;
        default: throw std::runtime_error("Unsupported load funct3");
    }

    store_reg(rd, value);
    pc_ += 4;
}

void CPU::exec_store(uint32_t inst) {
    uint32_t funct3 = (inst >> 12) & 0x7;
    uint32_t rs1    = (inst >> 15) & 0x1f;
    uint32_t rs2    = (inst >> 20) & 0x1f;

    uint32_t imm11_5 = (inst >> 25) & 0x7f;
    uint32_t imm4_0  = (inst >> 7) & 0x1f;
    int32_t imm = sign_extend((imm11_5 << 5) | imm4_0, 12);

    uint32_t addr = load_reg(rs1) + imm;
    uint32_t value = load_reg(rs2);

    switch (funct3) {
        case 0x0: bus_.store8(addr, static_cast<uint8_t>(value & 0xff)); break;
        case 0x1: bus_.store16(addr, static_cast<uint16_t>(value & 0xffff)); break;
        case 0x2: bus_.store32(addr, value); break;
        default: throw std::runtime_error("Unsupported store funct3");
    }

    pc_ += 4;
}

void CPU::exec_op_imm(uint32_t inst) {
    uint32_t rd     = (inst >> 7) & 0x1f;
    uint32_t funct3 = (inst >> 12) & 0x7;
    uint32_t rs1    = (inst >> 15) & 0x1f;
    int32_t imm     = sign_extend(inst >> 20, 12);

    uint32_t a = load_reg(rs1);
    uint32_t result = 0;

    switch (funct3) {
        case 0x0: result = a + static_cast<uint32_t>(imm); break;
        case 0x2: result = (static_cast<int32_t>(a) < imm) ? 1 : 0; break;
        case 0x3: result = (a < static_cast<uint32_t>(imm)) ? 1 : 0; break;
        case 0x4: result = a ^ static_cast<uint32_t>(imm); break;
        case 0x6: result = a | static_cast<uint32_t>(imm); break;
        case 0x7: result = a & static_cast<uint32_t>(imm); break;
        case 0x1: {
            uint32_t shamt = (inst >> 20) & 0x1f;
            result = a << shamt;
            break;
        }
        case 0x5: {
            uint32_t shamt = (inst >> 20) & 0x1f;
            uint32_t funct7 = (inst >> 25) & 0x7f;
            if (funct7 == 0x00) result = a >> shamt;
            else if (funct7 == 0x20) result = static_cast<uint32_t>(static_cast<int32_t>(a) >> shamt);
            else throw std::runtime_error("Unsupported shift-imm funct7");
            break;
        }
        default:
            throw std::runtime_error("Unsupported op-imm funct3");
    }

    store_reg(rd, result);
    pc_ += 4;
}

void CPU::exec_op(uint32_t inst) {
    uint32_t rd     = (inst >> 7) & 0x1f;
    uint32_t funct3 = (inst >> 12) & 0x7;
    uint32_t rs1    = (inst >> 15) & 0x1f;
    uint32_t rs2    = (inst >> 20) & 0x1f;
    uint32_t funct7 = (inst >> 25) & 0x7f;

    uint32_t a = load_reg(rs1);
    uint32_t b = load_reg(rs2);
    uint32_t result = 0;

    switch (funct3) {
        case 0x0:
            if (funct7 == 0x00) result = a + b;
            else if (funct7 == 0x20) result = a - b;
            else throw std::runtime_error("Unsupported ADD/SUB funct7");
            break;
        case 0x1: result = a << (b & 0x1f); break;
        case 0x2: result = (static_cast<int32_t>(a) < static_cast<int32_t>(b)) ? 1 : 0; break;
        case 0x3: result = (a < b) ? 1 : 0; break;
        case 0x4: result = a ^ b; break;
        case 0x5:
            if (funct7 == 0x00) result = a >> (b & 0x1f);
            else if (funct7 == 0x20) result = static_cast<uint32_t>(static_cast<int32_t>(a) >> (b & 0x1f));
            else throw std::runtime_error("Unsupported SRL/SRA funct7");
            break;
        case 0x6: result = a | b; break;
        case 0x7: result = a & b; break;
        default:
            throw std::runtime_error("Unsupported op funct3");
    }

    store_reg(rd, result);
    pc_ += 4;
}

void CPU::exec_system(uint32_t inst) {
    if (inst == 0x00000073) {
        bus_.store32(Bus::SIM_HALT, 1);
        pc_ += 4;
        return;
    }

    if (inst == 0x00100073) {
        bus_.store32(Bus::SIM_HALT, 1);
        pc_ += 4;
        return;
    }

    throw std::runtime_error("Unsupported system instruction");
}
